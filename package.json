{
  "name": "@tsci/tscircuit.dataset-srj20-partial-bga-breakouts",
  "version": "1.0.0",
  "description": "Partial BGA breakout simple-route JSON dataset with intentionally missing pads",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "circuits",
    "dataset-dist",
    "scripts",
    "pages",
    "cosmos.config.json",
    "cosmos.decorator.tsx",
    "graphics-debug-react.d.ts",
    "index.html",
    "index.js",
    "index.d.ts"
  ],
  "keywords": [
    "tscircuit",
    "circuit",
    "pcb",
    "electronics",
    "bga"
  ],
  "scripts": {
    "generate": "node scripts/generate-dataset.mjs",
    "build:dataset-dist": "node scripts/build-dataset-dist.mjs",
    "build": "tsci build circuits/sample001/sample001.circuit.tsx",
    "snapshot": "tsci snapshot circuits/sample001/sample001.circuit.tsx",
    "snapshot:update": "tsci snapshot circuits/sample001/sample001.circuit.tsx --update",
    "start": "cosmos",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dev": "tsci dev"
  },
  "devDependencies": {
    "@tscircuit/capacity-autorouter": "^0.0.484",
    "@tscircuit/core": "^0.0.733",
    "@tscircuit/eval": "^0.0.766",
    "@types/react": "^19.2.14",
    "bun-match-svg": "^0.0.11",
    "graphics-debug": "^0.0.94",
    "react": "^19.2.1",
    "react-cosmos": "^7.3.0",
    "react-cosmos-plugin-vite": "^7.3.0",
    "react-dom": "^19.2.1",
    "tscircuit": "^0.0.1672",
    "typescript": "^5.0.0",
    "vite": "^8.0.12"
  }
}
